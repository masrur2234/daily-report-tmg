generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DashboardUpload {
  id        String   @id @default(cuid())
  fileName  String
  uploadDate String   // YYYY-MM-DD format for date selection
  createdAt DateTime @default(now())
  
  kreditAO     KreditAO[]
  mutasiAO     MutasiAO[]
  tabunganFO   TabunganFO[]
  depositoFO   DepositoFO[]
}

model KreditAO {
  id        String          @id @default(cuid())
  uploadId  String
  upload    DashboardUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  nama      String
  noa       Float   @default(0)
  os        Float   @default(0)
  lancar    Float   @default(0)
  dpk       Float   @default(0)
  totNpl    Float   @default(0)
  rr        Float   @default(0)
  npl       Float   @default(0)
}

model MutasiAO {
  id         String          @id @default(cuid())
  uploadId   String
  upload     DashboardUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  nama       String
  noaBefore  Float   @default(0)
  osBefore   Float   @default(0)
  noaNow     Float   @default(0)
  osNow      Float   @default(0)
  mutasiNoa  Float   @default(0)
  mutasiOs   Float   @default(0)
}

model TabunganFO {
  id        String          @id @default(cuid())
  uploadId  String
  upload    DashboardUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  nama      String
  noaBefore Float   @default(0)
  osBefore  Float   @default(0)
  noaNow    Float   @default(0)
  osNow     Float   @default(0)
  mutasiNoa Float   @default(0)
  mutasiOs  Float   @default(0)
}

model DepositoFO {
  id        String          @id @default(cuid())
  uploadId  String
  upload    DashboardUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  nama      String
  noaBefore Float   @default(0)
  osBefore  Float   @default(0)
  noaNow    Float   @default(0)
  osNow     Float   @default(0)
  mutasiNoa Float   @default(0)
  mutasiOs  Float   @default(0)
}
